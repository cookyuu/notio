# Database
NOTIO_DB_HOST=localhost
NOTIO_DB_PORT=5432
NOTIO_DB_NAME=notio
NOTIO_DB_USERNAME=notio
NOTIO_DB_PASSWORD=notio

# Redis
NOTIO_REDIS_HOST=localhost
NOTIO_REDIS_PORT=6379
NOTIO_REDIS_PASSWORD=

# AI / RAG (Ollama)
NOTIO_OLLAMA_URL=http://localhost:11434
NOTIO_LLM_MODEL=llama3.2:3b
NOTIO_EMBED_MODEL=nomic-embed-text
NOTIO_EMBED_DIM=768
NOTIO_RAG_TOP_K=5
NOTIO_LLM_TIMEOUT=30s
NOTIO_EMBED_TIMEOUT=15s
NOTIO_STREAMING_TIMEOUT=120s
NOTIO_LLM_RETRY_MAX_ATTEMPTS=3
NOTIO_LLM_RETRY_BACKOFF_INITIAL_INTERVAL=1s
NOTIO_LLM_RETRY_BACKOFF_MAX_INTERVAL=10s
NOTIO_LLM_RETRY_BACKOFF_MULTIPLIER=2.0

# JWT
NOTIO_JWT_SECRET=your-256-bit-secret-key-change-this-in-production-please-use-a-secure-random-string

# Server
NOTIO_SERVER_PORT=8080

# Firebase (optional for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# API Keys (optional)
CLAUDE_API_KEY=
OPENAI_API_KEY=
